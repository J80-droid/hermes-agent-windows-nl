# Team Hermes CLI display — key=value (één per regel). Lege regels en # worden overgeslagen.
# Pas aan naar jullie afspraak; daarna APPLY_TEAM_DISPLAY.bat of (optioneel) na UPDATE_HERMES.bat.
# Geen geheimen hier — alleen display.* waarden.
#
# streaming=false: bij final_response_markdown=render streamt streaming=true ruwe markdown
# tijdens generatie; Rich komt op het eindpaneel. Team-default false = geen token-stream,
# alleen Rich eindpaneel. Hermes dwingt render+streaming=false bij load_config al af.

streaming=false
final_response_markdown=render
assistant_render_style=institutional_rich
assistant_palette=demo
assistant_label_columns=true
compact=false
skin=default

# Beschikbare assistant_palette waarden (built-in + config/palettes.yaml):
#   demo    - Monokai-inspired (cyaan/groen/magenta/geel)  [default]
#   hermes  - Goud/amber (alleen voor legacy-compat)
#   neutral - Wit/grijs (toegankelijkheid)
#   monokai, dracula, tokyo, nordic, pacific
# Zie: python scripts/diagnose_renderer.py --show-palettes
