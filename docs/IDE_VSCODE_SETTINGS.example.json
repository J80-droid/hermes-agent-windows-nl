{
  "python.defaultInterpreterPath": "${env:USERPROFILE}/miniconda3/envs/hermes-env/python.exe",
  "python.terminal.activateEnvironment": false,
  "python.terminal.activateEnvInCurrentTerminal": false,
  "files.associations": {
    "*.ps1": "powershell",
    "*.psm1": "powershell",
    "*.psd1": "powershell"
  },
  "powershell.scriptAnalysis.enable": true,
  "powershell.scriptAnalysis.settingsPath": "windows/PSScriptAnalyzerSettings.psd1",
  "powershell.analyzeOnlyOpenDocuments": true,
  "powershell.scriptAnalysis.useScriptPath": true
}
