# =============================================================================
# domains.yaml — enige bron van waarheid voor RAG multi-domein
# Documentatie-index: docs/README.md
# Twee fasen (index vs. chat): docs/RAG_TWEE_FASEN.md
# Model (alle profielen): docs/PROFILE_MODEL_INHERITANCE.md — NIET in profiel-yaml
# Kopieer naar: %USERPROFILE%\data\domains.yaml
#
# Nieuw domein toevoegen:
#   1. Kopieer het blok onder "Sjabloon nieuw domein" naar domains:
#   2. Maak raw_source_files\<source_dir>\ met bronbestanden
#   3. Maak Hermes-profiel %LOCALAPPDATA%\hermes\profiles\<profile_name>\
#      MCP: run sync_profile_mcp_from_domains.py (schrijft mcp_servers: — geen handmatig mcp.servers)
#      Geen model: in config — model komt uit ~/.hermes/config.yaml (docs/PROFILE_MODEL_INHERITANCE.md)
#   4. update_knowledge.bat --list  (moet het nieuwe domein tonen)
#   5. update_knowledge.bat <naam>  of update_knowledge.bat (alle domeinen)
#
# 99_Archive bewust NIET opnemen (geen actieve index).
# =============================================================================
version: '1.0'

personal_brain:
  path: ~/data/personal_brain
  files:
    - who_you_are.md
    - what_you_want.md
    - how_you_work.md
    - boundaries.md

# --- Verplicht: gedeelde laag (altijd eerste in ingest bij --all) ---
core_domain:
  name: core
  description: Gedeelde kennis die alle domeinen nodig hebben (Personal Brain + test.txt)
  source_dir: 00_Core
  lancedb_path: ~/data/lancedb/core
  mcp_name: lancedb-core
  # profile_name default = name (core)

# --- Domeinen (volgorde = ingest-volgorde bij update_knowledge.bat zonder argument) ---
domains:
  - name: academics
    source_dir: 01_Academics_Beta
    description: Onderwijs, curricula, wetenschappelijke bronnen
    lancedb_path: ~/data/lancedb/academics
    mcp_name: lancedb-academics
    profile_name: academics
    # media_policy: sidecar_or_skip   # default — geen Whisper op media zonder sidecar

  - name: operations
    source_dir: 02_Professional_Operations
    description: Professionele processen, best practices, operaties
    lancedb_path: ~/data/lancedb/operations
    mcp_name: lancedb-operations
    profile_name: operations

  - name: trading
    source_dir: 03_Algorithmic_Trading_AI
    description: Algoritmische trading, AI modellen, marktanalyse
    lancedb_path: ~/data/lancedb/trading
    mcp_name: lancedb-trading
    profile_name: trading

  # Legal: één RAG-bucket; rechtsgebieden via submappen (Arbeidsrecht/, Klokkenluiders/, …).
  # Geen aparte domains:-entry per rechtsgebied — zie docs/LEGAL_DOMAIN_ARCHITECTURE.md
  - name: legal
    source_dir: 04_Legal_Corporate
    description: Juridisch domein (lenzen arb/bbk/aanspr/klok/corp); submappen onder 04_Legal_Corporate
    lancedb_path: ~/data/lancedb/legal
    mcp_name: lancedb-legal
    profile_name: legal
    ingest_env:
      HERMES_RAG_PDF_PYMUPDF_FIRST_MB: "5"
      HERMES_RAG_PYMUPDF_MAX_PAGES: "250"
      HERMES_RAG_CONVERT_TIMEOUT_SEC: "180"
      HERMES_RAG_EMBED_BATCH: "16"
    media_policy: whisper_when_missing
    media_ingest_env:
      HERMES_RAG_SKIP_WHISPER_WITHOUT_SIDECAR: "0"
      HERMES_WHISPER_MODEL: small
      HERMES_RAG_FILE_TIMEOUT_SEC: "0"
    quarantine_restore:
      1.1 Verzoekschrift Zaak 25-00294-C2515 GC Rijk - Min. Buitenlandse Zaken .pdf: Geschillencommissie Rijk/VERZOEKSCHRIFT J. 
      1.1 Verzoekschrift Zaak 25-00294-C2515 GC Rijk - Min. Buitenlandse Zaken El Mourif_compressed.pdf: Geschillencommissie Rijk/VERZOEKSCHRIFT J. 

  - name: gaming
    source_dir: 05_Performance_Gaming
    description: Gaming prestaties, strategieen, technische analyse
    lancedb_path: ~/data/lancedb/gaming
    mcp_name: lancedb-gaming
    profile_name: gaming

  - name: philosophy
    source_dir: 06_Philosophy_Psychology
    description: Filosofie, psychologie, menselijk gedrag
    lancedb_path: ~/data/lancedb/philosophy
    mcp_name: lancedb-philosophy
    profile_name: philosophy

  - name: logistics
    source_dir: 07_Personal_Logistics
    description: Persoonlijke planning, organisatie, dagelijkse operaties
    lancedb_path: ~/data/lancedb/logistics
    mcp_name: lancedb-logistics
    profile_name: logistics

  - name: ventures
    source_dir: 08_Ventures_Incubator
    description: Startups, incubatie, business development
    lancedb_path: ~/data/lancedb/ventures
    mcp_name: lancedb-ventures
    profile_name: ventures

